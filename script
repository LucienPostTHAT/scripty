local function setTagsEnabled(state)
	tagsEnabled = state
	tagsButton.Text = state and "🏷 Tags: ON" or "🏷 Tags: OFF"
	tagsButton.BackgroundColor3 = state and COLORS.AccentDark or COLORS.Button

	if not state then
		for targetPlayer in pairs(trackedTags) do
			removeTag(targetPlayer)
		end
	else
		for _, otherPlayer in ipairs(Players:GetPlayers()) do
			if otherPlayer ~= player and otherPlayer.Character then
				createTag(otherPlayer, otherPlayer.Character)
			end
		end
	end
end

