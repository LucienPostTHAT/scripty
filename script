	b.TextColor3 = COLORS.Text
	b.TextSize = 12
	b.Font = Enum.Font.GothamSemibold
	b.BorderSizePixel = 0
	b.AutoButtonColor = false
	b.Parent = parent
	makeCorner(b, 10)
	makeStroke(b)
	createGlow(b, 0.88)
	return b
end

local function makeLabel(parent, text, y)
	local l = addLabel(Instance.new("TextLabel"))
	l.BackgroundTransparency = 1
	l.Size = UDim2.new(1, 0, 0, 20)
	l.Position = UDim2.new(0, 0, 0, y)
	l.Text = text
	l.TextColor3 = COLORS.SubText
	l.TextSize = 13
	l.Font = Enum.Font.Gotham
	l.TextXAlignment = Enum.TextXAlignment.Left
	l.Parent = parent
	return l
end

local function applyHover(button, activeFunc)
	button.MouseEnter:Connect(function()
		local target = COLORS.ButtonHover
		if activeFunc and activeFunc() then
			target = COLORS.AccentDark
		end
		TweenService:Create(button, TweenInfo.new(0.12), {BackgroundColor3 = target}):Play()
	end)

	button.MouseLeave:Connect(function()
		local target = COLORS.Button
		if activeFunc and activeFunc() then
			target = COLORS.AccentDark
		end
		TweenService:Create(button, TweenInfo.new(0.12), {BackgroundColor3 = target}):Play()
	end)
end

