local function getOverlayPosition(cornerName)
	if cornerName == "Top Left" then
		return UDim2.new(0, 12, 0, 12)
	elseif cornerName == "Top Right" then
		return UDim2.new(1, -162, 0, 12)
	elseif cornerName == "Bottom Left" then
		return UDim2.new(0, 12, 1, -70)
	else
		return UDim2.new(1, -162, 1, -70)
	end
end

local function setOverlayCorner(cornerName)
	overlayCorner = cornerName
	TweenService:Create(
		overlayFrame,
		TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{Position = getOverlayPosition(cornerName)}
	):Play()
end

