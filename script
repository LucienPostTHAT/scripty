RunService.RenderStepped:Connect(function(dt)
	if not unlocked then return end

	refreshCharacter()

	if humanoid then
		humanoid.WalkSpeed = walkSpeed
	end

	if noclip and character then
		for _, part in ipairs(character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = false
			end
		end
	end

	if tagsEnabled and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
		local myRoot = player.Character.HumanoidRootPart

		for targetPlayer, data in pairs(trackedTags) do
			local targetCharacter = targetPlayer.Character
			if not targetCharacter or not targetCharacter.Parent then
				removeTag(targetPlayer)
			else
				local currentHRP = targetCharacter:FindFirstChild("HumanoidRootPart")
				local currentHead = targetCharacter:FindFirstChild("Head")
				local currentHum = targetCharacter:FindFirstChildOfClass("Humanoid")

				if not currentHRP or not currentHead or not currentHum or currentHum.Health <= 0 then
					removeTag(targetPlayer)
				else
					local distance = (currentHRP.Position - myRoot.Position).Magnitude
					data.distanceLabel.Text = math.floor(distance) .. " studs"
					local _, onScreen = camera:WorldToViewportPoint(currentHead.Position)
					data.billboard.Enabled = onScreen and distance <= 220
				end
			end
		end
	end

	if statsOverlayEnabled then
		fpsFrames += 1
		fpsTimer += dt
		if fpsTimer >= 1 then
			currentFPS = math.floor(fpsFrames / fpsTimer)
			fpsFrames = 0
			fpsTimer = 0

			fpsLabel.Text = "FPS: " .. tostring(currentFPS)

			local pingValue = 0
			pcall(function()
				pingValue = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
			end)
			pingLabel.Text = "Ping: " .. tostring(pingValue) .. " ms"
		end
	end
end)

