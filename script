local function addButton(obj)
	table.insert(allButtons, obj)
	return obj
end

local function addLabel(obj)
	table.insert(allLabels, obj)
	return obj
end

local function addStroke(obj)
	table.insert(allStrokes, obj)
	return obj
end

local function createGlow(parent, transparency)
	local glow = Instance.new("UIStroke")
	glow.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	glow.Thickness = 3
	glow.Transparency = transparency or 0.82
	glow.Parent = parent
	table.insert(allGlows, glow)
	return glow
end

local function makeCorner(obj, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 10)
	c.Parent = obj
	return c
end

local function makeStroke(obj)
	local s = Instance.new("UIStroke")
	s.Color = COLORS.Line
	s.Parent = obj
	addStroke(s)
	return s
end

local function makeButton(parent, text, y, height)
	local b = addButton(Instance.new("TextButton"))
	b.Size = UDim2.new(1, 0, 0, height or 32)
	b.Position = UDim2.new(0, 0, 0, y)
	b.BackgroundColor3 = COLORS.Button
	b.Text = text
	b.TextColor3 = COLORS.Text
	b.TextSize = 13
	b.Font = Enum.Font.GothamSemibold
	b.BorderSizePixel = 0
	b.AutoButtonColor = false
	b.Parent = parent
	makeCorner(b, 10)
	makeStroke(b)
	createGlow(b, 0.88)
	return b
end

local function makeSmallButton(parent, text, xScale, xOffset, widthScale, widthOffset, y)
	local b = addButton(Instance.new("TextButton"))
	b.Size = UDim2.new(widthScale, widthOffset, 0, 30)
